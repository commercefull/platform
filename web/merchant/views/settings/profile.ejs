<!-- Page Header -->
<div class="page-header d-print-none">
  <div class="row align-items-center">
    <div class="col-auto">
      <h2 class="page-title">Profile Settings</h2>
    </div>
    <div class="col-auto ms-auto">
      <div class="btn-group">
        <a href="/merchant/settings/store" class="btn btn-outline-primary">Store Settings</a>
        <a href="/merchant/settings/notifications" class="btn btn-outline-primary">Notifications</a>
      </div>
    </div>
  </div>
</div>

<div class="row">
  <div class="col-md-8">
    <div class="card">
      <div class="card-header">
        <h3 class="card-title">Business Information</h3>
      </div>
      <div class="card-body">
        <form method="POST" action="/merchant/settings/profile">
          <div class="row">
            <div class="col-md-6">
              <div class="form-group mb-3">
                <label>Business Name</label>
                <input type="text" name="businessName" class="form-control" value="<%= merchant?.businessName || '' %>">
              </div>
            </div>
            <div class="col-md-6">
              <div class="form-group mb-3">
                <label>Contact Email</label>
                <input type="email" name="email" class="form-control" value="<%= merchant?.email || '' %>">
              </div>
            </div>
          </div>
          <div class="row">
            <div class="col-md-6">
              <div class="form-group mb-3">
                <label>Phone</label>
                <input type="tel" name="phone" class="form-control" value="<%= merchant?.phone || '' %>">
              </div>
            </div>
            <div class="col-md-6">
              <div class="form-group mb-3">
                <label>Website</label>
                <input type="url" name="website" class="form-control" value="<%= merchant?.website || '' %>">
              </div>
            </div>
          </div>
          <div class="form-group mb-3">
            <label>Description</label>
            <textarea name="description" class="form-control" rows="3"><%= merchant?.description || '' %></textarea>
          </div>
          <div class="row">
            <div class="col-md-6">
              <div class="form-group mb-3">
                <label>Address</label>
                <input type="text" name="address" class="form-control" value="<%= merchant?.address || '' %>">
              </div>
            </div>
            <div class="col-md-3">
              <div class="form-group mb-3">
                <label>City</label>
                <input type="text" name="city" class="form-control" value="<%= merchant?.city || '' %>">
              </div>
            </div>
            <div class="col-md-3">
              <div class="form-group mb-3">
                <label>Country</label>
                <input type="text" name="country" class="form-control" value="<%= merchant?.country || '' %>">
              </div>
            </div>
          </div>
          <button type="submit" class="btn btn-primary">Save Changes</button>
        </form>
      </div>
    </div>
  </div>

  <div class="col-md-4">
    <div class="card">
      <div class="card-header">
        <h3 class="card-title">Account Status</h3>
      </div>
      <div class="card-body">
        <dl>
          <dt>Status</dt>
          <dd>
            <span class="badge bg-<%= merchant?.status === 'active' ? 'success' : 'warning' %>">
              <%= merchant?.status || 'unknown' %>
            </span>
          </dd>
          <dt>Member Since</dt>
          <dd><%= merchant?.createdAt ? new Date(merchant.createdAt).toLocaleDateString() : '-' %></dd>
          <dt>Merchant ID</dt>
          <dd><code><%= merchant?.merchantId || '-' %></code></dd>
        </dl>
      </div>
    </div>
  </div>
</div>
