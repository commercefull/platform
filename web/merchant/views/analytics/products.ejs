<!-- Page Header -->
<div class="page-header d-print-none">
  <div class="row align-items-center">
    <div class="col-auto">
      <h2 class="page-title">Product Performance</h2>
    </div>
    <div class="col-auto ms-auto">
      <div class="btn-group">
        <a href="/merchant/analytics" class="btn btn-outline-primary">Sales Analytics</a>
        <a href="/merchant/analytics/customers" class="btn btn-outline-primary">Customer Insights</a>
      </div>
    </div>
  </div>
</div>

<!-- Products Table -->
<div class="card">
  <div class="card-header">
    <h3 class="card-title">Top Performing Products</h3>
  </div>
  <div class="card-body p-0">
    <table class="table table-striped">
      <thead>
        <tr>
          <th>#</th>
          <th>Product</th>
          <th>SKU</th>
          <th>Units Sold</th>
          <th>Revenue</th>
          <th>Avg Price</th>
        </tr>
      </thead>
      <tbody>
        <% if (products && products.length > 0) { %>
          <% products.forEach((product, index) => { %>
            <tr>
              <td><%= index + 1 %></td>
              <td><%= product.name || product.productName %></td>
              <td><code><%= product.sku || '-' %></code></td>
              <td><%= product.totalSold || product.unitsSold || 0 %></td>
              <td>$<%= ((product.revenue || 0) / 100).toFixed(2) %></td>
              <td>$<%= product.totalSold > 0 ? ((product.revenue / product.totalSold) / 100).toFixed(2) : '0.00' %></td>
            </tr>
          <% }) %>
        <% } else { %>
          <tr><td colspan="6" class="text-center text-muted py-4">No product performance data available</td></tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>
