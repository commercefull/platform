<!-- Credit Transaction History -->
<div class="card">
  <div class="card-header">
    <h3 class="card-title">Transaction History</h3>
    <div class="card-tools">
      <a href="/b2b/credit" class="btn btn-sm btn-default"><i class="fas fa-arrow-left"></i> Back to Credit</a>
    </div>
  </div>
  <div class="card-body p-0">
    <table class="table table-striped table-hover">
      <thead>
        <tr>
          <th>Date</th>
          <th>Type</th>
          <th>Amount</th>
          <th>Reference</th>
          <th>Notes</th>
        </tr>
      </thead>
      <tbody>
        <% if (transactions && transactions.length > 0) { %>
          <% transactions.forEach(tx => { %>
            <tr>
              <td><%= new Date(tx.createdAt).toLocaleString() %></td>
              <td><span class="badge badge-secondary"><%= tx.type %></span></td>
              <td class="<%= tx.amount >= 0 ? 'text-success' : 'text-danger' %>">
                <strong><%= tx.amount >= 0 ? '+' : '' %><%= tx.amount.toFixed(2) %></strong>
              </td>
              <td><%= tx.referenceId || '—' %></td>
              <td><%= tx.notes || '—' %></td>
            </tr>
          <% }) %>
        <% } else { %>
          <tr><td colspan="5" class="text-center text-muted py-4">No transactions found</td></tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>
