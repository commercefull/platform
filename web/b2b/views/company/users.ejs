<!-- Page Header -->
<div class="page-header d-print-none">
  <div class="row align-items-center">
    <div class="col-auto">
      <h2 class="page-title">Company Users</h2>
    </div>
    <div class="col-auto ms-auto">
      <div class="btn-group">
        <a href="/b2b/company" class="btn btn-outline-primary">Profile</a>
        <a href="/b2b/company/addresses" class="btn btn-outline-primary">Addresses</a>
      </div>
    </div>
  </div>
</div>

<div class="card">
  <div class="card-header">
    <h3 class="card-title">Team Members</h3>
  </div>
  <div class="card-body p-0">
    <table class="table table-striped">
      <thead>
        <tr>
          <th>Name</th>
          <th>Email</th>
          <th>Role</th>
          <th>Status</th>
          <th>Last Login</th>
        </tr>
      </thead>
      <tbody>
        <% if (users && users.length > 0) { %>
          <% users.forEach(user => { %>
            <tr>
              <td><%= user.firstName %> <%= user.lastName %></td>
              <td><%= user.email %></td>
              <td>
                <% const roleColors = { admin: 'danger', manager: 'warning', buyer: 'primary', viewer: 'secondary' }; %>
                <span class="badge bg-<%= roleColors[user.role] || 'secondary' %>"><%= user.role %></span>
              </td>
              <td>
                <span class="badge bg-<%= user.status === 'active' ? 'success' : 'secondary' %>"><%= user.status %></span>
              </td>
              <td><%= user.lastLoginAt ? new Date(user.lastLoginAt).toLocaleDateString() : 'Never' %></td>
            </tr>
          <% }) %>
        <% } else { %>
          <tr><td colspan="5" class="text-center text-muted py-4">No users found</td></tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>
