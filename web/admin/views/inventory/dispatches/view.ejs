<div class="page-header d-print-none"><div class="row g-2 align-items-center"><div class="col"><h2 class="page-title"><%= dispatch?.dispatchNumber || pageName %></h2></div><div class="col-auto ms-auto"><a href="/admin/dispatches" class="btn btn-outline-secondary">Back</a></div></div></div>
<section class="content"><div class="container-fluid"><%- include('../../partials/alerts') %><div class="row"><div class="col-md-8"><div class="card mb-3"><div class="card-header"><h3 class="card-title">Dispatch Details</h3></div><div class="card-body"><dl class="row mb-0"><dt class="col-sm-4">From Store</dt><dd class="col-sm-8"><%= dispatch.fromStoreId %></dd><dt class="col-sm-4">To Store</dt><dd class="col-sm-8"><%= dispatch.toStoreId %></dd><dt class="col-sm-4">Status</dt><dd class="col-sm-8"><span class="badge bg-info"><%= dispatch.status %></span></dd><dt class="col-sm-4">Requested By</dt><dd class="col-sm-8"><%= dispatch.requestedBy || '-' %></dd><dt class="col-sm-4">Notes</dt><dd class="col-sm-8"><%= dispatch.notes || '-' %></dd></dl></div></div><div class="card"><div class="card-header"><h3 class="card-title">Items</h3></div><div class="card-body table-responsive p-0"><table class="table table-hover"><thead><tr><th>Product</th><th>SKU</th><th>Requested</th><th>Dispatched</th><th>Received</th></tr></thead><tbody><% (dispatch.items || []).forEach(function(item) { %><tr><td><%= item.productName || item.productId %></td><td><%= item.sku || '-' %></td><td><%= item.requestedQuantity %></td><td><%= item.dispatchedQuantity || 0 %></td><td><%= item.receivedQuantity || 0 %></td></tr><% }) %></tbody></table></div></div></div><div class="col-md-4"><div class="card"><div class="card-header"><h3 class="card-title">Actions</h3></div><div class="card-body"><% if (dispatch.status === 'draft') { %><form method="POST" action="/admin/dispatches/<%= dispatch.dispatchId %>/approve" class="mb-2"><button class="btn btn-primary w-100" type="submit">Approve</button></form><form method="POST" action="/admin/dispatches/<%= dispatch.dispatchId %>/cancel"><button class="btn btn-outline-danger w-100" type="submit">Cancel</button></form><% } %><% if (dispatch.status === 'approved') { %><form method="POST" action="/admin/dispatches/<%= dispatch.dispatchId %>/dispatch"><button class="btn btn-primary w-100" type="submit">Mark Dispatched</button></form><% } %><% if (dispatch.status === 'dispatched' || dispatch.status === 'in_transit') { %><form method="POST" action="/admin/dispatches/<%= dispatch.dispatchId %>/receive" class="mb-2"><button class="btn btn-success w-100" type="submit">Mark Received</button></form><% } %></div></div></div></div></div></section>
