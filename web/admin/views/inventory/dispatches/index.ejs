<div class="page-header d-print-none"><div class="row g-2 align-items-center"><div class="col"><h2 class="page-title"><%= pageName %></h2></div><div class="col-auto ms-auto"><a href="/admin/dispatches/create" class="btn btn-primary">Create Dispatch</a></div></div></div>
<section class="content"><div class="container-fluid"><%- include('../../partials/alerts') %><div class="card mb-3"><div class="card-body"><form method="GET" class="row g-3"><div class="col-md-3"><label class="form-label">Status</label><input class="form-control" name="status" value="<%= filters.status || '' %>"></div><div class="col-md-3"><label class="form-label">From Store</label><select class="form-select" name="fromStoreId"><option value="">All</option><% (stores || []).forEach(function(store) { %><option value="<%= store.storeId %>" <%= filters.fromStoreId === store.storeId ? 'selected' : '' %>><%= store.name %></option><% }) %></select></div><div class="col-md-3"><label class="form-label">To Store</label><select class="form-select" name="toStoreId"><option value="">All</option><% (stores || []).forEach(function(store) { %><option value="<%= store.storeId %>" <%= filters.toStoreId === store.storeId ? 'selected' : '' %>><%= store.name %></option><% }) %></select></div><div class="col-md-3 d-flex align-items-end"><button class="btn btn-primary me-2" type="submit">Filter</button><a href="/admin/dispatches" class="btn btn-outline-secondary">Clear</a></div></form></div></div><div class="card"><div class="card-body table-responsive p-0"><table class="table table-hover"><thead><tr><th>Dispatch #</th><th>From</th><th>To</th><th>Status</th><th>Items</th><th>Requested By</th><th>Date</th><th></th></tr></thead><tbody><% (dispatches || []).forEach(function(dispatch) { %><tr><td><a href="/admin/dispatches/<%= dispatch.dispatchId %>"><%= dispatch.dispatchNumber %></a></td><td><%= dispatch.fromStoreId %></td><td><%= dispatch.toStoreId %></td><td><span class="badge bg-info"><%= dispatch.status %></span></td><td><%= (dispatch.items || []).length %></td><td><%= dispatch.requestedBy || '-' %></td><td><%= dispatch.createdAt ? new Date(dispatch.createdAt).toLocaleDateString() : '-' %></td><td><a class="btn btn-sm btn-outline-primary" href="/admin/dispatches/<%= dispatch.dispatchId %>">View</a></td></tr><% }) %><% if (!dispatches || dispatches.length === 0) { %><tr><td colspan="8" class="text-center text-muted py-4">No dispatches found.</td></tr><% } %></tbody></table></div></div></div></section>
