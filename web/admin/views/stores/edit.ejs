<div class="page-header d-print-none"><div class="row g-2 align-items-center"><div class="col"><h2 class="page-title"><%= pageName %></h2></div><div class="col-auto ms-auto"><a href="/admin/stores/<%= store?.storeId || formData.storeId %>" class="btn btn-outline-secondary">Back</a></div></div></div>
<section class="content"><div class="container-fluid"><%- include('../partials/alerts') %><div class="card"><div class="card-body"><form method="POST" action="/admin/stores/<%= store?.storeId || formData.storeId %>"><div class="row"><div class="col-md-6 mb-3"><label class="form-label">Name</label><input class="form-control" name="name" value="<%= formData.name || store?.name || '' %>" required></div><div class="col-md-6 mb-3"><label class="form-label">URL</label><input class="form-control" name="storeUrl" value="<%= formData.storeUrl || store?.storeUrl || '' %>"></div><div class="col-12 mb-3"><label class="form-label">Description</label><textarea class="form-control" name="description" rows="3"><%= formData.description || store?.description || '' %></textarea></div><div class="col-md-6 mb-3"><label class="form-label">Email</label><input class="form-control" name="storeEmail" value="<%= formData.storeEmail || store?.storeEmail || '' %>"></div><div class="col-md-6 mb-3"><label class="form-label">Phone</label><input class="form-control" name="storePhone" value="<%= formData.storePhone || store?.storePhone || '' %>"></div><div class="col-md-3 mb-3"><label class="form-label">Address Line 1</label><input class="form-control" name="addressLine1" value="<%= formData.addressLine1 || store?.address?.line1 || '' %>"></div><div class="col-md-3 mb-3"><label class="form-label">City</label><input class="form-control" name="city" value="<%= formData.city || store?.address?.city || '' %>"></div><div class="col-md-3 mb-3"><label class="form-label">State</label><input class="form-control" name="state" value="<%= formData.state || store?.address?.state || '' %>"></div><div class="col-md-3 mb-3"><label class="form-label">Postal Code</label><input class="form-control" name="postalCode" value="<%= formData.postalCode || store?.address?.postalCode || '' %>"></div><div class="col-md-3 mb-3"><label class="form-label">Country</label><input class="form-control" name="country" value="<%= formData.country || store?.address?.country || '' %>"></div><div class="col-md-3 form-check ms-2"><input class="form-check-input" type="checkbox" name="isActive" id="isActive" <%= (formData.isActive || store?.isActive) ? 'checked' : '' %>><label class="form-check-label" for="isActive">Active</label></div></div><button class="btn btn-primary" type="submit">Update Store</button></form></div></div></div></section>
