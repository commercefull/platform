<div class="page-header d-print-none"><div class="row g-2 align-items-center"><div class="col"><h2 class="page-title"><%= pageName %></h2></div><div class="col-auto ms-auto"><a href="/admin/stores" class="btn btn-outline-secondary">Back</a></div></div></div>
<section class="content"><div class="container-fluid"><%- include('../partials/alerts') %><div class="card"><div class="card-body"><form method="POST" action="/admin/stores"><div class="row"><div class="col-md-6 mb-3"><label class="form-label">Name</label><input class="form-control" name="name" value="<%= formData.name || '' %>" required></div><div class="col-md-6 mb-3"><label class="form-label">Store Type</label><select class="form-select" name="storeType"><option value="business_store">Business Store</option><option value="merchant_store">Merchant Store</option></select></div><div class="col-md-6 mb-3"><label class="form-label">Business</label><select class="form-select" name="businessId"><option value="">Select business</option><% (businesses || []).forEach(function(business) { %><option value="<%= business.businessId %>"><%= business.name %></option><% }) %></select></div><div class="col-md-6 mb-3"><label class="form-label">Parent Store</label><select class="form-select" name="parentStoreId"><option value="">None</option><% (stores || []).forEach(function(store) { %><option value="<%= store.storeId %>"><%= store.name %></option><% }) %></select></div><div class="col-12 mb-3"><label class="form-label">Description</label><textarea class="form-control" name="description" rows="3"><%= formData.description || '' %></textarea></div><div class="col-md-6 mb-3"><label class="form-label">Email</label><input class="form-control" name="storeEmail" value="<%= formData.storeEmail || '' %>"></div><div class="col-md-6 mb-3"><label class="form-label">Phone</label><input class="form-control" name="storePhone" value="<%= formData.storePhone || '' %>"></div><div class="col-md-3 mb-3"><label class="form-label">Address Line 1</label><input class="form-control" name="addressLine1" value="<%= formData.addressLine1 || '' %>"></div><div class="col-md-3 mb-3"><label class="form-label">City</label><input class="form-control" name="city" value="<%= formData.city || '' %>"></div><div class="col-md-3 mb-3"><label class="form-label">State</label><input class="form-control" name="state" value="<%= formData.state || '' %>"></div><div class="col-md-3 mb-3"><label class="form-label">Postal Code</label><input class="form-control" name="postalCode" value="<%= formData.postalCode || '' %>"></div><div class="col-md-3 mb-3"><label class="form-label">Country</label><input class="form-control" name="country" value="<%= formData.country || '' %>"></div><div class="col-md-3 form-check ms-2"><input class="form-check-input" type="checkbox" name="isHeadquarters" id="isHeadquarters"><label class="form-check-label" for="isHeadquarters">Is Headquarters</label></div></div><button class="btn btn-primary" type="submit">Create Store</button></form></div></div></div></section>
