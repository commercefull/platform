<div class="page-header d-print-none"><div class="row g-2 align-items-center"><div class="col"><h2 class="page-title"><%= pageName %></h2></div><div class="col-auto ms-auto"><a href="/admin/stores/<%= store?.storeId %>" class="btn btn-outline-secondary">Back</a></div></div></div>
<section class="content"><div class="container-fluid"><%- include('../partials/alerts') %><div class="row"><div class="col-md-5"><div class="card"><div class="card-header"><h3 class="card-title">Assign User</h3></div><div class="card-body"><form method="POST" action="/admin/stores/<%= store?.storeId %>/users"><div class="mb-3"><label class="form-label">User ID</label><input class="form-control" name="userId" required></div><div class="mb-3"><label class="form-label">Role</label><select class="form-select" name="role"><option value="cashier">Cashier</option><option value="manager">Manager</option><option value="admin">Admin</option></select></div><div class="mb-3"><label class="form-label">Permissions</label><input class="form-control" name="permissions" placeholder="comma,separated,permissions"></div><button class="btn btn-primary" type="submit">Assign User</button></form></div></div></div><div class="col-md-7"><div class="card"><div class="card-header"><h3 class="card-title">Assigned Users</h3></div><div class="card-body table-responsive p-0"><table class="table table-hover"><thead><tr><th>User</th><th>Role</th><th>Primary</th><th>Active</th><th></th></tr></thead><tbody><% (users || []).forEach(function(user) { %><tr><td><code><%= user.userId %></code></td><td><%= user.role %></td><td><%= user.isPrimary ? 'Yes' : 'No' %></td><td><%= user.isActive ? 'Yes' : 'No' %></td><td><form method="POST" action="/admin/stores/<%= store?.storeId %>/users/<%= user.userId %>?_method=DELETE"><button class="btn btn-sm btn-outline-danger" type="submit">Remove</button></form></td></tr><% }) %><% if (!users || users.length === 0) { %><tr><td colspan="5" class="text-center text-muted py-4">No users assigned.</td></tr><% } %></tbody></table></div></div></div></div></div></section>
