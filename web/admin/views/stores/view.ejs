<div class="page-header d-print-none">
  <div class="row g-2 align-items-center">
    <div class="col"><h2 class="page-title"><%= store?.name || pageName %></h2></div>
    <div class="col-auto ms-auto">
      <a href="/admin/stores/<%= store.storeId %>/edit" class="btn btn-primary me-2">Edit</a>
      <a href="/admin/stores" class="btn btn-outline-secondary">Back</a>
    </div>
  </div>
</div>
<section class="content">
  <div class="container-fluid">
    <%- include('../partials/alerts') %>
    <div class="row">
      <div class="col-md-8">
        <div class="card mb-3"><div class="card-header"><h3 class="card-title">Store Details</h3></div><div class="card-body"><dl class="row mb-0"><dt class="col-sm-4">Name</dt><dd class="col-sm-8"><%= store.name %></dd><dt class="col-sm-4">Type</dt><dd class="col-sm-8"><%= store.isHeadquarters ? 'Headquarters' : 'Outlet' %></dd><dt class="col-sm-4">Email</dt><dd class="col-sm-8"><%= store.storeEmail || '-' %></dd><dt class="col-sm-4">Phone</dt><dd class="col-sm-8"><%= store.storePhone || '-' %></dd><dt class="col-sm-4">Address</dt><dd class="col-sm-8"><%= store.address ? [store.address.line1, store.address.city, store.address.state, store.address.postalCode, store.address.country].filter(Boolean).join(', ') : '-' %></dd></dl></div></div>
        <div class="card mb-3"><div class="card-header"><h3 class="card-title">Linked Users</h3></div><div class="card-body"><% if ((users || []).length === 0) { %><p class="text-muted mb-0">No users assigned.</p><% } else { %><ul class="list-group list-group-flush"><% users.forEach(function(user) { %><li class="list-group-item d-flex justify-content-between align-items-center"><span><code><%= user.userId %></code></span><span class="badge bg-info"><%= user.role %></span></li><% }) %></ul><% } %><div class="mt-3"><a href="/admin/stores/<%= store.storeId %>/users" class="btn btn-sm btn-outline-primary">Manage Users</a></div></div></div>
      </div>
      <div class="col-md-4">
        <div class="card mb-3"><div class="card-header"><h3 class="card-title">Recent Orders</h3></div><div class="card-body"><% if ((recentOrders || []).length === 0) { %><p class="text-muted mb-0">No recent orders.</p><% } else { %><ul class="list-group list-group-flush"><% recentOrders.forEach(function(order) { %><li class="list-group-item"><a href="/admin/orders/<%= order.orderId %>">#<%= order.orderNumber %></a><br><small class="text-muted"><%= order.orderSource || 'web' %></small></li><% }) %></ul><% } %></div></div>
        <div class="card"><div class="card-header"><h3 class="card-title">Recent Dispatches</h3></div><div class="card-body"><% if ((recentDispatches || []).length === 0) { %><p class="text-muted mb-0">No dispatches.</p><% } else { %><ul class="list-group list-group-flush"><% recentDispatches.forEach(function(dispatch) { %><li class="list-group-item"><a href="/admin/dispatches/<%= dispatch.dispatchId %>"><%= dispatch.dispatchNumber %></a><br><small class="text-muted"><%= dispatch.status %></small></li><% }) %></ul><% } %></div></div>
      </div>
    </div>
  </div>
</section>
