<!-- Page Header -->
<div class="page-header d-print-none">
  <div class="row g-2 align-items-center">
    <div class="col">
      <h2 class="page-title"><%= priceList.name %></h2>
      <div class="text-muted mt-1">
        <a href="/admin/b2b/price-lists">Price Lists</a> &rsaquo; <%= priceList.name %>
      </div>
    </div>
    <div class="col-auto">
      <a href="/admin/b2b/price-lists/<%= priceList.b2bPriceListId %>/edit" class="btn btn-outline-secondary">Edit</a>
    </div>
  </div>
</div>

<section class="content">
  <div class="container-fluid">
    <%- include('../../partials/alerts') %>

    <div class="row">
      <div class="col-md-4">
        <div class="card mb-3">
          <div class="card-header">
            <h3 class="card-title">Price List Details</h3>
          </div>
          <div class="card-body">
            <dl class="row">
              <dt class="col-sm-5">ID</dt>
              <dd class="col-sm-7"><code><%= priceList.b2bPriceListId.substring(0, 8) %>...</code></dd>
              <dt class="col-sm-5">Currency</dt>
              <dd class="col-sm-7"><%= priceList.currency %></dd>
              <dt class="col-sm-5">Company</dt>
              <dd class="col-sm-7"><%= priceList.b2bCompanyId ? priceList.b2bCompanyId.substring(0, 8) + '...' : 'Global' %></dd>
              <dt class="col-sm-5">Status</dt>
              <dd class="col-sm-7">
                <span class="badge bg-<%= priceList.isActive ? 'success' : 'secondary' %>">
                  <%= priceList.isActive ? 'Active' : 'Inactive' %>
                </span>
              </dd>
              <dt class="col-sm-5">Notes</dt>
              <dd class="col-sm-7"><%= priceList.notes || '-' %></dd>
              <dt class="col-sm-5">Created</dt>
              <dd class="col-sm-7"><%= new Date(priceList.createdAt).toLocaleDateString() %></dd>
            </dl>
          </div>
        </div>
      </div>

      <div class="col-md-8">
        <div class="card">
          <div class="card-header">
            <h3 class="card-title">Price List Items</h3>
            <span class="float-end text-muted"><%= (items || []).length %> items</span>
          </div>
          <div class="card-body table-responsive p-0">
            <table class="table table-hover">
              <thead>
                <tr>
                  <th>Product ID</th>
                  <th>Variant ID</th>
                  <th>Price</th>
                  <th>Currency</th>
                  <th>Updated</th>
                </tr>
              </thead>
              <tbody>
                <% (items || []).forEach(function(item) { %>
                <tr>
                  <td><code><%= item.productId.substring(0, 8) %>...</code></td>
                  <td><%= item.productVariantId ? item.productVariantId.substring(0, 8) + '...' : '-' %></td>
                  <td><strong><%= (item.price || 0).toFixed(2) %></strong></td>
                  <td><%= item.currency %></td>
                  <td><%= new Date(item.updatedAt).toLocaleDateString() %></td>
                </tr>
                <% }); %>
                <% if ((items || []).length === 0) { %>
                <tr><td colspan="5" class="text-center text-muted py-4">No items in this price list.</td></tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
