<!-- Page Header -->
<div class="page-header d-print-none">
  <div class="row g-2 align-items-center">
    <div class="col">
      <h2 class="page-title">Payment Settings</h2>
    </div>
  </div>
</div>

<section class="content">
  <div class="container-fluid">
    <%- include('../../partials/alerts') %>

    <div class="card">
      <div class="card-header">
        <h3 class="card-title">Per-Merchant Payment Settings</h3>
        <span class="float-end text-muted"><%= (settings || []).length %> merchants configured</span>
      </div>
      <div class="card-body table-responsive p-0">
        <table class="table table-hover">
          <thead>
            <tr>
              <th>Merchant ID</th>
              <th>Provider</th>
              <th>Enabled</th>
              <th>Updated</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% (settings || []).forEach(function(s) { %>
            <tr>
              <td><code><%= s.merchantId %></code></td>
              <td><span class="badge bg-info"><%= s.provider %></span></td>
              <td>
                <span class="badge bg-<%= s.isEnabled ? 'success' : 'secondary' %>">
                  <%= s.isEnabled ? 'Enabled' : 'Disabled' %>
                </span>
              </td>
              <td><%= new Date(s.updatedAt).toLocaleDateString() %></td>
              <td>
                <button type="button" class="btn btn-sm btn-outline-primary"
                  data-bs-toggle="modal" data-bs-target="#editModal"
                  data-merchant-id="<%= s.merchantId %>"
                  data-provider="<%= s.provider %>"
                  data-enabled="<%= s.isEnabled %>">
                  Edit
                </button>
              </td>
            </tr>
            <% }); %>
            <% if ((settings || []).length === 0) { %>
            <tr><td colspan="5" class="text-center text-muted py-4">No payment settings configured.</td></tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</section>

<!-- Edit Modal -->
<div class="modal fade" id="editModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <form method="POST" id="editForm" action="">
        <div class="modal-header">
          <h5 class="modal-title">Update Payment Settings</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <div class="mb-3">
            <label class="form-label">Provider</label>
            <input type="text" class="form-control" name="provider" id="editProvider" required>
          </div>
          <div class="mb-3">
            <label class="form-label">Status</label>
            <select class="form-select" name="isEnabled" id="editEnabled">
              <option value="true">Enabled</option>
              <option value="false">Disabled</option>
            </select>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-primary">Save</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
document.getElementById('editModal').addEventListener('show.bs.modal', function(e) {
  const btn = e.relatedTarget;
  const merchantId = btn.getAttribute('data-merchant-id');
  document.getElementById('editForm').action = '/admin/payments/settings/' + merchantId;
  document.getElementById('editProvider').value = btn.getAttribute('data-provider');
  document.getElementById('editEnabled').value = btn.getAttribute('data-enabled');
});
</script>
