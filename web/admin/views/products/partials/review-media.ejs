<div class="card">
  <div class="card-header">
    <h3 class="card-title">Review Media</h3>
  </div>
  <div class="card-body">
    <% if (mediaByReview && mediaByReview.length > 0) { %>
      <% mediaByReview.forEach(function(entry) { %>
        <% if (entry.media && entry.media.length > 0) { %>
        <div class="mb-4">
          <h6 class="text-muted mb-2">Review by <%= entry.review.reviewerName || 'Anonymous' %> — <small><%= new Date(entry.review.createdAt).toLocaleDateString() %></small></h6>
          <div class="d-flex flex-wrap gap-2">
            <% entry.media.forEach(function(m) { %>
            <div class="position-relative">
              <% if (m.type === 'image') { %>
                <img src="<%= m.url %>" alt="Review media" style="width:100px;height:100px;object-fit:cover;border-radius:4px;">
              <% } else { %>
                <div class="d-flex align-items-center justify-content-center bg-light border rounded" style="width:100px;height:100px;">
                  <i class="fas fa-video text-muted fa-2x"></i>
                </div>
              <% } %>
              <form method="POST" action="/admin/products/<%= productId %>/reviews/media/<%= m.productReviewMediaId %>?_method=DELETE" class="position-absolute top-0 end-0" onsubmit="return confirm('Delete this media?')">
                <input type="hidden" name="_method" value="DELETE">
                <button type="submit" class="btn btn-danger btn-sm p-0" style="width:20px;height:20px;font-size:10px;">&times;</button>
              </form>
            </div>
            <% }); %>
          </div>
        </div>
        <% } %>
      <% }); %>
    <% } else { %>
    <div class="text-muted">No review media for this product.</div>
    <% } %>
  </div>
</div>
