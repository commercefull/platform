<%- include("../partials/header") %>

<main class="min-h-screen bg-gray-50 py-8 px-4 sm:px-6 lg:px-8">
  <div class="max-w-4xl mx-auto">
    <!-- Header -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between mb-8">
      <div>
        <h1 class="text-3xl font-bold text-gray-900">My Membership</h1>
        <p class="mt-2 text-sm text-gray-600">View and manage your membership</p>
      </div>
      <a href="/membership" class="mt-4 sm:mt-0 inline-flex items-center px-4 py-2 border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 transition-colors text-sm">
        View All Plans
      </a>
    </div>

    <% if (membership) { %>
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- Membership Info -->
        <div class="lg:col-span-2 space-y-6">
          <div class="bg-white shadow-lg rounded-xl overflow-hidden">
            <div class="bg-gradient-to-r from-indigo-600 to-purple-600 px-6 py-6">
              <div class="flex items-center justify-between">
                <div>
                  <h2 class="text-xl font-bold text-white"><%= membership.tierName || membership.planName || 'Membership' %></h2>
                  <p class="text-indigo-200 mt-1">Member since <%= membership.startDate ? new Date(membership.startDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long' }) : '-' %></p>
                </div>
                <%
                  let statusColor = 'gray';
                  if (membership.status === 'active') statusColor = 'green';
                  else if (membership.status === 'expired') statusColor = 'red';
                  else if (membership.status === 'suspended') statusColor = 'yellow';
                %>
                <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-white text-<%= statusColor %>-700">
                  <%= membership.status %>
                </span>
              </div>
            </div>
            <div class="px-6 py-6">
              <div class="grid grid-cols-2 gap-6">
                <div>
                  <dt class="text-sm font-medium text-gray-500">Current Period</dt>
                  <dd class="mt-1 text-sm text-gray-900">
                    <%= membership.currentPeriodStart ? new Date(membership.currentPeriodStart).toLocaleDateString() : '-' %>
                    &mdash;
                    <%= membership.currentPeriodEnd ? new Date(membership.currentPeriodEnd).toLocaleDateString() : '-' %>
                  </dd>
                </div>
                <div>
                  <dt class="text-sm font-medium text-gray-500">Renewal Date</dt>
                  <dd class="mt-1 text-sm text-gray-900"><%= membership.renewalDate ? new Date(membership.renewalDate).toLocaleDateString() : 'N/A' %></dd>
                </div>
                <% if (membership.pointsBalance !== undefined) { %>
                <div>
                  <dt class="text-sm font-medium text-gray-500">Points Balance</dt>
                  <dd class="mt-1 text-lg font-semibold text-indigo-600"><%= membership.pointsBalance || 0 %> pts</dd>
                </div>
                <% } %>
                <% if (membership.totalSavings !== undefined) { %>
                <div>
                  <dt class="text-sm font-medium text-gray-500">Total Savings</dt>
                  <dd class="mt-1 text-lg font-semibold text-green-600">$<%= ((membership.totalSavings || 0) / 100).toFixed(2) %></dd>
                </div>
                <% } %>
              </div>
            </div>
          </div>

          <!-- Benefits -->
          <% if (benefits && benefits.length > 0) { %>
          <div class="bg-white shadow-lg rounded-xl overflow-hidden">
            <div class="px-6 py-4 border-b border-gray-200">
              <h3 class="text-lg font-semibold text-gray-900">Your Benefits</h3>
            </div>
            <div class="px-6 py-4">
              <div class="space-y-4">
                <% benefits.forEach(benefit => { %>
                  <div class="flex items-start p-4 bg-gray-50 rounded-lg">
                    <svg class="w-6 h-6 text-green-500 mr-3 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                    <div>
                      <h4 class="font-medium text-gray-900"><%= benefit.name || benefit.title %></h4>
                      <% if (benefit.description) { %>
                        <p class="text-sm text-gray-600 mt-1"><%= benefit.description %></p>
                      <% } %>
                    </div>
                  </div>
                <% }) %>
              </div>
            </div>
          </div>
          <% } %>
        </div>

        <!-- Sidebar -->
        <div class="space-y-6">
          <% if (membership.status === 'active') { %>
          <div class="bg-white shadow-lg rounded-xl p-6">
            <h3 class="text-lg font-semibold text-gray-900 mb-4">Manage</h3>
            <div class="space-y-3">
              <a href="/membership" class="block w-full text-center px-4 py-2 border border-indigo-600 text-indigo-600 rounded-lg hover:bg-indigo-50 transition-colors text-sm font-medium">
                Upgrade Plan
              </a>
              <form method="POST" action="/membership/cancel" onsubmit="return confirm('Are you sure you want to cancel your membership?')">
                <button type="submit" class="w-full px-4 py-2 border border-red-300 text-red-600 rounded-lg hover:bg-red-50 transition-colors text-sm font-medium">
                  Cancel Membership
                </button>
              </form>
            </div>
          </div>
          <% } %>
          <% if (membership.status === 'expired') { %>
          <div class="bg-white shadow-lg rounded-xl p-6">
            <h3 class="text-lg font-semibold text-gray-900 mb-4">Renew</h3>
            <p class="text-sm text-gray-600 mb-4">Your membership has expired. Renew to continue enjoying benefits.</p>
            <a href="/membership" class="block w-full text-center px-4 py-2 bg-indigo-600 text-white rounded-lg hover:bg-indigo-700 transition-colors text-sm font-medium">
              Renew Membership
            </a>
          </div>
          <% } %>
        </div>
      </div>
    <% } else { %>
      <!-- No Membership -->
      <div class="bg-white shadow-lg rounded-xl p-12 text-center">
        <div class="mx-auto h-24 w-24 bg-indigo-100 rounded-full flex items-center justify-center mb-6">
          <svg class="h-12 w-12 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
          </svg>
        </div>
        <h3 class="text-lg font-medium text-gray-900 mb-2">You're not a member yet</h3>
        <p class="text-gray-600 mb-6">Join a membership plan to unlock exclusive benefits, rewards, and discounts.</p>
        <a href="/membership" class="inline-flex items-center px-6 py-3 bg-indigo-600 text-white font-medium rounded-lg hover:bg-indigo-700 transition-colors">
          Browse Membership Plans
        </a>
      </div>
    <% } %>
  </div>
</main>

<%- include("../partials/footer") %>
