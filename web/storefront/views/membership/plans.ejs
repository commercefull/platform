<%- include("../partials/header") %>

<main class="min-h-screen bg-gray-50 py-8 px-4 sm:px-6 lg:px-8">
  <div class="max-w-7xl mx-auto">
    <!-- Header -->
    <div class="text-center mb-12">
      <h1 class="text-3xl font-bold text-gray-900">Membership Plans</h1>
      <p class="mt-2 text-lg text-gray-600">Unlock exclusive benefits and rewards</p>
    </div>

    <% if (plans && plans.length > 0) { %>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <% plans.forEach(plan => { %>
          <div class="bg-white rounded-xl shadow-lg overflow-hidden hover:shadow-xl transition-shadow flex flex-col">
            <div class="bg-gradient-to-r from-indigo-600 to-purple-600 px-6 py-6 text-center">
              <h3 class="text-xl font-bold text-white"><%= plan.name %></h3>
              <% if (plan.price > 0) { %>
                <div class="mt-2">
                  <span class="text-4xl font-extrabold text-white">$<%= ((plan.price || 0) / 100).toFixed(2) %></span>
                  <span class="text-indigo-200">/<%= plan.billingPeriod || 'year' %></span>
                </div>
              <% } else { %>
                <div class="mt-2">
                  <span class="text-3xl font-extrabold text-white">Free</span>
                </div>
              <% } %>
            </div>
            <div class="px-6 py-6 flex-1 flex flex-col">
              <% if (plan.description) { %>
                <p class="text-gray-600 mb-4"><%= plan.description %></p>
              <% } %>
              <ul class="space-y-3 mb-6 flex-1">
                <% if (plan.benefits && Array.isArray(plan.benefits)) { %>
                  <% plan.benefits.forEach(benefit => { %>
                    <li class="flex items-start text-sm text-gray-700">
                      <svg class="w-5 h-5 text-green-500 mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                      </svg>
                      <%= typeof benefit === 'string' ? benefit : benefit.name || benefit.description %>
                    </li>
                  <% }) %>
                <% } %>
                <% if (plan.pointsMultiplier && plan.pointsMultiplier > 1) { %>
                  <li class="flex items-start text-sm text-gray-700">
                    <svg class="w-5 h-5 text-yellow-500 mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"></path>
                    </svg>
                    <%= plan.pointsMultiplier %>x loyalty points
                  </li>
                <% } %>
                <% if (plan.freeShipping) { %>
                  <li class="flex items-start text-sm text-gray-700">
                    <svg class="w-5 h-5 text-blue-500 mr-2 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4"></path>
                    </svg>
                    Free shipping on all orders
                  </li>
                <% } %>
              </ul>
              <a href="/membership/<%= plan.membershipTierId || plan.id %>" class="block w-full text-center px-6 py-3 bg-indigo-600 text-white font-medium rounded-lg hover:bg-indigo-700 transition-colors">
                View Details
              </a>
            </div>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <div class="bg-white rounded-xl shadow-lg p-12 text-center">
        <div class="mx-auto h-24 w-24 bg-gray-100 rounded-full flex items-center justify-center mb-6">
          <svg class="h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
          </svg>
        </div>
        <h3 class="text-lg font-medium text-gray-900 mb-2">No membership plans available</h3>
        <p class="text-gray-600">Check back later for membership opportunities.</p>
      </div>
    <% } %>
  </div>
</main>

<%- include("../partials/footer") %>
