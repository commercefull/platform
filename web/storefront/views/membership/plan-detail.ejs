<%- include("../partials/header") %>

<main class="min-h-screen bg-gray-50 py-8 px-4 sm:px-6 lg:px-8">
  <div class="max-w-4xl mx-auto">
    <!-- Header -->
    <div class="mb-8">
      <a href="/membership" class="text-blue-600 hover:text-blue-800 text-sm">&larr; Back to Membership Plans</a>
      <h1 class="text-3xl font-bold text-gray-900 mt-2"><%= plan.name %></h1>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <!-- Plan Details -->
      <div class="lg:col-span-2 space-y-6">
        <div class="bg-white shadow-lg rounded-xl overflow-hidden">
          <div class="bg-gradient-to-r from-indigo-600 to-purple-600 px-6 py-6">
            <div class="flex items-center justify-between">
              <h2 class="text-xl font-bold text-white"><%= plan.name %></h2>
              <div>
                <% if (plan.price > 0) { %>
                  <span class="text-3xl font-extrabold text-white">$<%= ((plan.price || 0) / 100).toFixed(2) %></span>
                  <span class="text-indigo-200">/<%= plan.billingPeriod || 'year' %></span>
                <% } else { %>
                  <span class="text-3xl font-extrabold text-white">Free</span>
                <% } %>
              </div>
            </div>
          </div>
          <div class="px-6 py-6">
            <% if (plan.description) { %>
              <p class="text-gray-700 mb-6"><%= plan.description %></p>
            <% } %>

            <h3 class="text-lg font-semibold text-gray-900 mb-4">Benefits</h3>
            <div class="space-y-4">
              <% if (benefits && benefits.length > 0) { %>
                <% benefits.forEach(benefit => { %>
                  <div class="flex items-start p-4 bg-gray-50 rounded-lg">
                    <svg class="w-6 h-6 text-green-500 mr-3 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                    <div>
                      <h4 class="font-medium text-gray-900"><%= benefit.name || benefit.title %></h4>
                      <% if (benefit.description) { %>
                        <p class="text-sm text-gray-600 mt-1"><%= benefit.description %></p>
                      <% } %>
                    </div>
                  </div>
                <% }) %>
              <% } else { %>
                <p class="text-gray-500 text-center py-4">Benefit details coming soon.</p>
              <% } %>
            </div>
          </div>
        </div>
      </div>

      <!-- Sidebar -->
      <div class="space-y-6">
        <div class="bg-white shadow-lg rounded-xl p-6">
          <h3 class="text-lg font-semibold text-gray-900 mb-4">Join This Plan</h3>
          <% if (plan.price > 0) { %>
            <div class="text-center mb-4">
              <span class="text-3xl font-extrabold text-gray-900">$<%= ((plan.price || 0) / 100).toFixed(2) %></span>
              <span class="text-gray-500">/<%= plan.billingPeriod || 'year' %></span>
            </div>
          <% } %>
          <form method="POST" action="/membership/join">
            <input type="hidden" name="planId" value="<%= plan.membershipTierId || plan.id %>">
            <button type="submit" class="w-full px-6 py-3 bg-indigo-600 text-white font-medium rounded-lg hover:bg-indigo-700 transition-colors">
              Join Now
            </button>
          </form>
          <p class="text-xs text-gray-500 text-center mt-3">Cancel anytime. No long-term commitment.</p>
        </div>

        <% if (plan.pointsMultiplier || plan.freeShipping || plan.discountPercentage) { %>
        <div class="bg-white shadow-lg rounded-xl p-6">
          <h3 class="text-lg font-semibold text-gray-900 mb-4">Highlights</h3>
          <ul class="space-y-3">
            <% if (plan.pointsMultiplier && plan.pointsMultiplier > 1) { %>
              <li class="flex items-center text-sm text-gray-700">
                <span class="w-8 h-8 bg-yellow-100 rounded-full flex items-center justify-center mr-3">
                  <svg class="w-4 h-4 text-yellow-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"></path>
                  </svg>
                </span>
                <%= plan.pointsMultiplier %>x loyalty points
              </li>
            <% } %>
            <% if (plan.freeShipping) { %>
              <li class="flex items-center text-sm text-gray-700">
                <span class="w-8 h-8 bg-blue-100 rounded-full flex items-center justify-center mr-3">
                  <svg class="w-4 h-4 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4"></path>
                  </svg>
                </span>
                Free shipping
              </li>
            <% } %>
            <% if (plan.discountPercentage) { %>
              <li class="flex items-center text-sm text-gray-700">
                <span class="w-8 h-8 bg-green-100 rounded-full flex items-center justify-center mr-3">
                  <svg class="w-4 h-4 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"></path>
                  </svg>
                </span>
                <%= plan.discountPercentage %>% off all orders
              </li>
            <% } %>
          </ul>
        </div>
        <% } %>
      </div>
    </div>
  </div>
</main>

<%- include("../partials/footer") %>
