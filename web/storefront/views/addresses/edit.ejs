<%- include("../partials/header") %>

<main class="min-h-screen bg-gray-50 py-8 px-4 sm:px-6 lg:px-8">
  <div class="max-w-2xl mx-auto">
    <div class="mb-8">
      <a href="/addresses" class="text-blue-600 hover:text-blue-800 text-sm">&larr; Back to Addresses</a>
      <h1 class="text-3xl font-bold text-gray-900 mt-2">Edit Address</h1>
    </div>

    <div class="bg-white shadow-lg rounded-xl p-6">
      <form method="POST" action="/addresses/<%= address.addressId %>">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">First Name</label>
            <input type="text" name="firstName" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent" value="<%= address.firstName || '' %>" required>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Last Name</label>
            <input type="text" name="lastName" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent" value="<%= address.lastName || '' %>" required>
          </div>
        </div>
        <div class="mt-4">
          <label class="block text-sm font-medium text-gray-700 mb-1">Address Line 1</label>
          <input type="text" name="street1" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent" value="<%= address.street1 || '' %>" required>
        </div>
        <div class="mt-4">
          <label class="block text-sm font-medium text-gray-700 mb-1">Address Line 2 (optional)</label>
          <input type="text" name="street2" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent" value="<%= address.street2 || '' %>">
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mt-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">City</label>
            <input type="text" name="city" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent" value="<%= address.city || '' %>" required>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">State / Province</label>
            <input type="text" name="state" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent" value="<%= address.state || '' %>" required>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Postal Code</label>
            <input type="text" name="postalCode" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent" value="<%= address.postalCode || '' %>" required>
          </div>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mt-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Country</label>
            <input type="text" name="country" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent" value="<%= address.country || '' %>" required>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Phone (optional)</label>
            <input type="tel" name="phone" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent" value="<%= address.phone || '' %>">
          </div>
        </div>
        <div class="mt-4">
          <label class="block text-sm font-medium text-gray-700 mb-1">Label (optional)</label>
          <input type="text" name="label" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent" value="<%= address.label || '' %>" placeholder="e.g. Home, Office">
        </div>
        <div class="mt-4">
          <label class="flex items-center">
            <input type="checkbox" name="isDefault" class="rounded border-gray-300 text-blue-600 focus:ring-blue-500" <%= address.isDefault ? 'checked' : '' %>>
            <span class="ml-2 text-sm text-gray-700">Set as default address</span>
          </label>
        </div>
        <div class="mt-6 flex gap-3">
          <button type="submit" class="px-6 py-2 bg-blue-600 text-white font-medium rounded-lg hover:bg-blue-700 transition-colors">Update Address</button>
          <a href="/addresses" class="px-6 py-2 border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 transition-colors">Cancel</a>
        </div>
      </form>
    </div>
  </div>
</main>

<%- include("../partials/footer") %>
