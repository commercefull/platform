<%- include("../partials/header") %>

<main class="min-h-screen bg-gray-50 py-8 px-4 sm:px-6 lg:px-8">
  <div class="max-w-4xl mx-auto">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between mb-8">
      <div>
        <h1 class="text-3xl font-bold text-gray-900">My Returns</h1>
        <p class="mt-2 text-sm text-gray-600">Track and manage your return requests</p>
      </div>
      <a href="/returns/create" class="mt-4 sm:mt-0 inline-flex items-center px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors">
        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h10a8 8 0 018 8v2M3 10l6 6m-6-6l6-6"></path>
        </svg>
        Request Return
      </a>
    </div>

    <% if (returns && returns.length > 0) { %>
      <div class="space-y-4">
        <% returns.forEach(ret => { %>
          <div class="bg-white shadow-lg rounded-xl overflow-hidden hover:shadow-xl transition-shadow">
            <div class="px-6 py-4 border-b border-gray-200 bg-gradient-to-r from-gray-50 to-gray-100">
              <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2">
                <div>
                  <h3 class="text-lg font-semibold text-gray-900">Return #<%= ret.returnNumber || ret.returnId?.substring(0, 8) %></h3>
                  <p class="text-sm text-gray-600">Order #<%= ret.orderNumber || '-' %> &middot; <%= ret.createdAt ? new Date(ret.createdAt).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) : '-' %></p>
                </div>
                <div class="flex items-center gap-3">
                  <%
                    let statusColor = 'gray';
                    if (ret.status === 'approved') statusColor = 'green';
                    else if (ret.status === 'pending') statusColor = 'yellow';
                    else if (ret.status === 'rejected') statusColor = 'red';
                    else if (ret.status === 'processing') statusColor = 'blue';
                    else if (ret.status === 'completed') statusColor = 'green';
                  %>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-<%= statusColor %>-100 text-<%= statusColor %>-800">
                    <%= ret.status %>
                  </span>
                </div>
              </div>
            </div>
            <div class="px-6 py-4 flex items-center justify-between">
              <div class="text-sm text-gray-600">
                <span class="font-medium">Reason:</span> <%= ret.reason || '-' %>
              </div>
              <a href="/returns/<%= ret.returnId %>" class="inline-flex items-center px-4 py-2 border border-blue-600 text-blue-600 rounded-lg hover:bg-blue-50 transition-colors text-sm">
                View Details
              </a>
            </div>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <div class="bg-white shadow-lg rounded-xl p-12 text-center">
        <div class="mx-auto h-24 w-24 bg-gray-100 rounded-full flex items-center justify-center mb-6">
          <svg class="h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h10a8 8 0 018 8v2M3 10l6 6m-6-6l6-6"></path>
          </svg>
        </div>
        <h3 class="text-lg font-medium text-gray-900 mb-2">No returns</h3>
        <p class="text-gray-600">You haven't made any return requests.</p>
      </div>
    <% } %>
  </div>
</main>

<%- include("../partials/footer") %>
