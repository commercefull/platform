<%- include("../partials/header") %>

<main class="min-h-screen bg-gray-50 py-8 px-4 sm:px-6 lg:px-8">
  <div class="max-w-2xl mx-auto">
    <!-- Header -->
    <div class="mb-8">
      <a href="/notifications" class="text-blue-600 hover:text-blue-800 text-sm">&larr; Back to Notifications</a>
      <h1 class="text-3xl font-bold text-gray-900 mt-2">Push Notification Devices</h1>
      <p class="mt-2 text-sm text-gray-600">Manage devices registered for push notifications</p>
    </div>

    <% if (typeof successMsg !== 'undefined' && successMsg) { %>
      <div class="mb-4 p-4 bg-green-50 border border-green-200 rounded-lg text-green-800 text-sm"><%= successMsg %></div>
    <% } %>
    <% if (typeof errorMsg !== 'undefined' && errorMsg) { %>
      <div class="mb-4 p-4 bg-red-50 border border-red-200 rounded-lg text-red-800 text-sm"><%= errorMsg %></div>
    <% } %>

    <!-- Register Device Form -->
    <div class="bg-white shadow-lg rounded-xl overflow-hidden mb-6">
      <div class="px-6 py-5 border-b border-gray-200">
        <h2 class="text-lg font-semibold text-gray-900">Register a Device</h2>
      </div>
      <form method="POST" action="/notifications/devices" class="px-6 py-5 space-y-4">
        <div>
          <label for="deviceToken" class="block text-sm font-medium text-gray-700 mb-1">Device Token</label>
          <input
            type="text"
            id="deviceToken"
            name="deviceToken"
            required
            placeholder="Enter your device push token"
            class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
          />
        </div>
        <div>
          <label for="platform" class="block text-sm font-medium text-gray-700 mb-1">Platform</label>
          <select
            id="platform"
            name="platform"
            required
            class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
          >
            <option value="">Select platform</option>
            <option value="ios">iOS</option>
            <option value="android">Android</option>
            <option value="web">Web</option>
          </select>
        </div>
        <button
          type="submit"
          class="inline-flex items-center px-5 py-2 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700 transition-colors"
        >
          Register Device
        </button>
      </form>
    </div>

    <!-- Registered Devices List -->
    <div class="bg-white shadow-lg rounded-xl overflow-hidden">
      <div class="px-6 py-5 border-b border-gray-200">
        <h2 class="text-lg font-semibold text-gray-900">Registered Devices</h2>
      </div>

      <% if (!devices || devices.length === 0) { %>
        <div class="px-6 py-10 text-center text-gray-500 text-sm">
          No devices registered yet.
        </div>
      <% } else { %>
        <ul class="divide-y divide-gray-200">
          <% devices.forEach(function(device) { %>
            <li class="px-6 py-4 flex items-center justify-between">
              <div>
                <p class="text-sm font-medium text-gray-900 capitalize"><%= device.platform %></p>
                <p class="text-xs text-gray-500 mt-0.5 font-mono truncate max-w-xs"><%= device.deviceToken %></p>
                <p class="text-xs text-gray-400 mt-0.5">Added <%= new Date(device.createdAt).toLocaleDateString() %></p>
              </div>
              <form method="POST" action="/notifications/devices/<%= encodeURIComponent(device.deviceToken) %>/delete">
                <button
                  type="submit"
                  class="text-sm text-red-600 hover:text-red-800 font-medium transition-colors"
                  onclick="return confirm('Remove this device?')"
                >
                  Remove
                </button>
              </form>
            </li>
          <% }) %>
        </ul>
      <% } %>
    </div>
  </div>
</main>

<%- include("../partials/footer") %>
