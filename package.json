{
  "name": "commercefull",
  "version": "1.0.0",
  "main": "index.js",
  "license": "Apache-2.0",
  "scripts": {
    "dev": "NODE_ENV=development nodemon app.ts",
    "prd": "yarn prd:build && yarn prd:run",
    "prd:run": "NODE_ENV=production node --env-file=.env --watch ./app.mjs",
    "prd:run:pm2": "NODE_ENV=production pm2 start -i max node --env-file=.env --name commercefull -- ./app.mjs",
    "prd:build": "yarn css:build && npx esbuild app.ts --bundle --minify --platform=node --target=es2022 --format=esm --outfile=app.mjs --external:./node_modules/* --banner:js='import { createRequire as topLevelCreateRequire } from \"module\"; const require = topLevelCreateRequire(import.meta.url);'",
    "db": "docker run --rm -d -P -p 127.0.0.1:5433:5432 --env-file ./.env --name commerce-db postgres:18-alpine",
    "db:stop": "docker stop commerce-db",
    "db:migrate": "knex migrate:latest --env development",
    "db:migrate:new": "knex migrate:make",
    "db:rollback": "knex migrate:rollback --env development",
    "db:rollback:all": "knex migrate:rollback --all --env development",
    "db:seed": "knex seed:run --env development",
    "db:types": "ts-node --transpile-only scripts/generate-knex-types.ts",
    "test": "jest",
    "test:unit": "jest ./features --collectCoverage=false",
    "test:int": "jest ./tests/integration --collectCoverage=false --detectOpenHandles --runInBand",
    "test:e2e": "npx cypress run --headless --browser chrome",
    "lint": "npx tsc --noEmit && eslint . --ext .ts,.js",
    "lint:errors": "eslint . --ext .ts,.js --quiet",
    "lint:fix": "eslint . --ext .ts,.js --fix",
    "format": "prettier --write \"**/*.{ts,js,json,md,html,css,scss}\"",
    "format:check": "prettier --check \"**/*.{ts,js,json,md,html,css,scss}\"",
    "package:upgrade": "yarn upgrade --latest",
    "code:lint": "knip",
    "sec:audit": "yarn audit --groups dependencies",
    "sec:check": "yarn audit --groups dependencies --level high",
    "css:build": "npx tailwindcss -i ./public/stylesheets/storefront/main.css -o ./public/stylesheets/storefront/compiled.css --minify",
    "css:watch": "npx tailwindcss -i ./public/stylesheets/storefront/main.css -o ./public/stylesheets/storefront/compiled.css --watch",
    "job:new:merchant": "NODE_ENV=development node --env-file=.env -r ts-node/register ./modules/merchant/interface/jobs/new-merchant.ts",
    "job:new:business": "NODE_ENV=development node --env-file=.env -r ts-node/register ./modules/business/interface/jobs/new-business.ts",
    "job:new:admin": "NODE_ENV=development node --env-file=.env -r ts-node/register ./modules/identity/interface/jobs/new-admin.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.990.0",
    "@aws-sdk/s3-request-presigner": "^3.990.0",
    "bcryptjs": "3.0.3",
    "body-parser": "2.2.2",
    "compression": "1.8.1",
    "connect-flash": "0.1.1",
    "connect-pg-simple": "10.0.0",
    "connect-redis": "^9.0.0",
    "cookie-parser": "1.4.7",
    "cors": "^2.8.6",
    "dinero.js": "1.9.1",
    "ejs": "4.0.1",
    "express": "5.2.1",
    "express-session": "1.19.0",
    "express-validator": "7.3.1",
    "express-winston": "^4.2.0",
    "helmet": "8.1.0",
    "hpp": "^0.2.3",
    "i18next": "25.8.10",
    "i18next-fs-backend": "2.6.1",
    "i18next-http-middleware": "3.9.2",
    "ioredis": "^5.9.3",
    "jsonwebtoken": "9.0.3",
    "moment": "2.30.1",
    "multer": "^2.0.2",
    "node-cache": "^5.1.2",
    "node-mailjet": "6.0.11",
    "nodemailer": "8.0.1",
    "passport": "0.7.0",
    "pg": "^8.18.0",
    "sharp": "^0.34.5",
    "stripe": "20.3.1",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/body-parser": "1.19.6",
    "@types/compression": "1.8.1",
    "@types/connect-flash": "0.0.40",
    "@types/cookie-parser": "1.4.10",
    "@types/cors": "^2.8.17",
    "@types/dinero.js": "1.9.4",
    "@types/ejs": "3.1.5",
    "@types/express": "5.0.6",
    "@types/express-session": "1.18.2",
    "@types/hpp": "^0.2.6",
    "@types/jest": "30.0.0",
    "@types/jsonwebtoken": "9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.0.0",
    "@types/node": "25.2.3",
    "@types/nodemailer": "7.0.10",
    "@types/passport": "1.0.17",
    "@types/pg": "8.16.0",
    "@types/sharp": "^0.32.0",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^11.0.0",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "autoprefixer": "^10.4.24",
    "axios": "1.13.5",
    "cypress": "15.10.0",
    "cypress-cucumber-preprocessor": "4.3.1",
    "dotenv": "^17.3.1",
    "esbuild": "0.27.3",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.3.0",
    "jest": "30.2.0",
    "knex": "^3.1.0",
    "knex-types": "0.5.0",
    "knip": "5.83.1",
    "nodemon": "3.1.11",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.1.18",
    "ts-jest": "29.4.6",
    "ts-node": "10.9.2",
    "typescript": "5.9.3"
  }
}
